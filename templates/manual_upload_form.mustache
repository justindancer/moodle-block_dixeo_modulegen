{{!
    Manual upload form: file upload and submit.

    @template block_dixeo_modulegen/manual_upload_form
    @package    block_dixeo_modulegen
}}
<form id="dixeo_manual_upload_form" method="post" class="manual-upload-form" enctype="multipart/form-data">
    <div class="modal-header">
        <h5 class="modal-title w-100 text-center" id="manualUploadModalLabel"></h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="{{#str}}close, moodle{{/str}}">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
    <div class="modal-body">
        <div class="form-group mb-0">
            <div id="manual-upload-dropzone" class="manual-upload-dropzone border rounded p-3 text-center">
                <p id="manual-upload-drag-text" class="manual-upload-drag-text mb-2 small text-muted">{{#str}}manual_upload_drag, block_dixeo_modulegen{{/str}}</p>
                <p id="manual-upload-description"
                    class="manual-upload-description mb-2 small text-muted"
                    role="note"
                    aria-live="polite"></p>
                <p id="manual-upload-filename" class="manual-upload-filename mb-0 small font-weight-bold d-none"></p>
                <input type="file"
                    id="manual-upload-file"
                    name="file"
                    class="sr-only"
                    aria-labelledby="manual-upload-drag-text"
                    required>
                <button type="button" id="manual-upload-browse" class="btn btn-outline-secondary btn-sm">
                    {{#str}}manual_upload_browse, block_dixeo_modulegen{{/str}}
                </button>
            </div>
        </div>
        <input type="hidden" id="manual-upload-modtype" name="modtype" value="">
        <input type="hidden" id="manual-upload-courseid" name="courseid" value="{{courseid}}">
        <input type="hidden" id="manual-upload-sectionnumber" name="sectionnumber" value="{{sectionid}}">
        <input type="hidden" id="manual-upload-beforemod" name="beforemod" value="0">
    </div>
    <div class="modal-footer justify-content-end">
        <button type="submit" id="manual_upload_submit" class="btn btn-primary" title="{{#str}}add, block_dixeo_modulegen{{/str}}">
            <img src="{{config.wwwroot}}/blocks/dixeo_modulegen/pix/dixeo-white.svg" alt="" width="20" height="20" class="mr-1">
            {{#str}}add, block_dixeo_modulegen{{/str}}
        </button>
    </div>
</form>
