{{!
    Queue status bar: Active/Queued (spinner) + Needs attention (warning). Display only.

    @template block_dixeo_modulegen/queue_stats
    @package    block_dixeo_modulegen
    @author     Josemaria Bolanos <admin@mako.digital>
    @author     Pierre FACQ <pierre.facq@edunao.com>
}}
<div class="queue-status-bar d-flex align-items-center justify-content-between small">
    <div class="stats-container d-flex align-items-center" role="group" aria-label="{{#str}}queuemodaltitle, block_dixeo_modulegen{{/str}}">
        <span class="stat stat-active d-flex align-items-center" title="{{#str}}activequeued, block_dixeo_modulegen{{/str}}: {{#stats.active}}{{stats.active}}{{/stats.active}}{{^stats.active}}{{idle}}{{/stats.active}}">
            <i class="fa fa-spinner mr-1" aria-hidden="true"></i>
            <span class="count">{{#stats.active}}{{stats.active}}{{/stats.active}}{{^stats.active}}{{idle}}{{/stats.active}}</span>
        </span>
        {{#stats.errors}}
        <span class="stat stat-errors d-flex align-items-center" title="{{#str}}needsattention, block_dixeo_modulegen{{/str}}: {{stats.errors}}">
            <i class="fa fa-exclamation-triangle mr-1" aria-hidden="true"></i>
            <span class="count">{{stats.errors}}</span>
        </span>
        {{/stats.errors}}
    </div>
    <div class="queue-status-bar-right" aria-hidden="true"></div>
</div>
