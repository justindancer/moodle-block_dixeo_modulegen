{{!
    Queue panel: header, loading state, task list. Rendered inside expanded container.

    @template block_dixeo_modulegen/queue
    @package    block_dixeo_modulegen
    @author     Josemaria Bolanos <admin@mako.digital>
    @author     Pierre FACQ <pierre.facq@edunao.com>
}}
<div class="queue-container d-flex flex-column h-100">
    <div class="queue-header d-flex justify-content-between align-items-center border-bottom flex-shrink-0">
        <span class="font-weight-bold mb-0">{{#str}}queuemodaltitle, block_dixeo_modulegen{{/str}}</span>
        <button type="button" class="queue-close-button btn btn-sm btn-link p-0" aria-label="{{#str}}close, moodle{{/str}}">
            <i class="fa fa-chevron-down" aria-hidden="true"></i>
        </button>
    </div>
    <div class="queue-loading d-none flex-grow-1 justify-content-center align-items-center p-4" aria-live="polite" aria-busy="false">
        <div class="text-center text-muted">
            <i class="fa fa-spinner fa-pulse fa-2x" aria-hidden="true"></i>
            <p class="mt-2 mb-0">{{#str}}loading, moodle{{/str}}</p>
        </div>
    </div>
    <div class="task-list list-group list-group-flush flex-grow-1 overflow-auto mx-0">
        {{#tasks}}
            {{> block_dixeo_modulegen/task}}
        {{/tasks}}
        {{^tasks}}
            <p class="text-muted text-center queue-empty-msg mb-0">{{#str}}notasksinthequeue, block_dixeo_modulegen{{/str}}</p>
        {{/tasks}}
    </div>
</div>
