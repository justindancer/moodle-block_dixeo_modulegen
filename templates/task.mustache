{{!
    Single queue task row: icon (no bg, larger), title/link, status badge, remove X.

    @template block_dixeo_modulegen/task
    @package    block_dixeo_modulegen
}}
<div class="task-item list-group-item list-group-item-action flex-column align-items-start border-0 border-bottom rounded-0 status_{{status}}"
    data-task-id="{{id}}"
    data-module-name="{{modulename}}"
    data-status="{{status}}"
    data-timestarted="{{timestarted}}"
    data-sortorder="{{sortorder}}"
    role="listitem">
    <div class="d-flex flex-row w-100 align-items-center">
        <div class="task-item-icon">
            <img src="{{iconurl}}" alt="" class="task-item-icon-img" width="40" height="40"/>
        </div>
        <div class="task-details flex-grow-1 min-width-0 ml-2">
            {{#link}}
                <a class="task-title task-title-clamp mb-0" href="{{link}}" title="{{display_title}}">{{display_title}}</a>
            {{/link}}
            {{^link}}
                <span class="task-title task-title-clamp mb-0" title="{{display_title}}">{{display_title}}</span>
            {{/link}}
            <span class="task-instructions-trigger-wrapper d-inline-flex align-items-center" title="{{#str}}viewinstructions, block_dixeo_modulegen{{/str}}">
                <span class="task-instructions-trigger" role="button" tabindex="0" aria-label="{{#str}}viewinstructions, block_dixeo_modulegen{{/str}}"><i class="fa fa-wand-magic-sparkles task-instructions-icon" aria-hidden="true"></i></span>
                <span class="d-none task-instructions-content">{{instructions}}</span>
            </span>
            {{! Status: Queued }}
            {{#isqueued}}
                {{^isnext}}
                    <span class="task-status task-status-queued small text-muted d-inline-flex">{{statusdisplay}}</span>
                {{/isnext}}
            {{/isqueued}}
            {{! Status: Next }}
            {{#isnext}}
                <span class="task-status task-status-next small text-muted d-inline-flex">{{statusdisplay}}</span>
            {{/isnext}}
            {{! Status: Processing - green box with elapsed time }}
            {{#isprocessing}}
                <div class="task-status task-status-processing d-inline-flex">
                    <span class="processing-label">{{#str}}processing, block_dixeo_modulegen{{/str}}...</span>
                    <span class="elapsed-time">0:00</span>
                </div>
            {{/isprocessing}}
            {{! Status: Failed + Retry link }}
            {{#isfailed}}
                <span class="task-status-inline d-inline-flex align-items-center flex-wrap">
                    <span class="task-status task-status-error small">{{statusdisplay}}</span>
                    <span class="task-status-sep" aria-hidden="true"></span>
                    <a href="#" class="task-retry-link small" data-task-id="{{id}}" data-module-name="{{modulename}}" data-sectionnumber="{{sectionnumber}}" data-beforemod="{{beforemod}}" data-courseid="{{courseid}}">{{#str}}retry, block_dixeo_modulegen{{/str}}</a>
                </span>
            {{/isfailed}}
            {{! Status: Cancelled (status 4, not isfailed for display) }}
            {{#iscancelled}}
                <span class="task-status task-status-cancelled small text-muted d-inline-flex">{{statusdisplay}}</span>
            {{/iscancelled}}
            {{! Status: Completed - short date }}
            {{#iscompleted}}
                <span class="task-status task-status-completed small text-muted d-inline-flex">{{completed_on_short}}</span>
            {{/iscompleted}}
        </div>
        <div class="task-actions d-flex align-items-center ml-2 flex-shrink-0">
            {{! Remove X: queued (remove from queue) or completed (remove from display). Not for processing. }}
            {{#canremove}}
                <button type="button" class="task-remove-button btn btn-link p-0 text-muted" data-task-id="{{id}}" title="{{removetooltip}}" aria-label="{{removetooltip}}">
                    <i class="fa fa-times" aria-hidden="true"></i>
                </button>
            {{/canremove}}
        </div>
    </div>
</div>
