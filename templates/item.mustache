{{!
    @template block_dixeo_modulegen/item

    Chooser item template.

    Example context (json):
    {
        "shortname": "Activity shortname",
        "displayname": "Activity name",
        "description": "Activity description",
        "iconurl": "https://dixeo.com/local/dixeo/images/modules/glossary.png",
        "backgroundColor": "#399be2",
        "requirements": [],
        "options": {
            "href": "https://external.link/to/generate/activity",
            "enabled": true,
            "beta": false
        }
    }
}}
<div class="optioninfo text-center">
    <a class="d-flex flex-column ai {{^options.enabled}} disabled {{/options.enabled}}"
        tabindex="-1"
        {{#options.enabled}}
            data-toggle="modal"
            data-target="#generationModal"
            title="{{#str}} addnew, moodle, {{displayname}} {{/str}}"
        {{/options.enabled}}
        {{^options.enabled}}
            title="{{#str}} notavailable, block_dixeo_modulegen{{/str}}"
        {{/options.enabled}}
        href="{{options.href}}"
        data-modal-title="{{#str}} addnew, moodle, {{displayname}} {{/str}}"
        data-module-name="{{shortname}}"
        data-section-number="{{sectionid}}"
    >
        {{#options.beta}}<div class="badge badge-warning" style="position: absolute; left: 50%;">Beta</div>{{/options.beta}}
        <div class="optionicon mt-2 mb-1 mx-auto icon-no-margin modicon_{{shortname}} activityiconcontainer" style="background-color: {{backgroundColor}};">
            <img src="{{iconurl}}" alt="{{displayname}} icon"/>
        </div>
        <div class="optionname clamp-2 bold">{{displayname}}</div>
    </a>
</div>
